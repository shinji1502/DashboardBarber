<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox styleClass="app-shell" xmlns="http://javafx.com/javafx/9" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PengaturanController">
    <children>
        <VBox styleClass="sidebar">
            <children>
                <Label styleClass="brand" text="BarberPro" />
                <Button onAction="#showDashboard" styleClass="menu-button" text="◉ Dashboard" />
                <Button onAction="#showPelanggan" styleClass="menu-button" text="◈ Pelanggan" />
                <Button onAction="#showLaporan" styleClass="menu-button" text="◌ Laporan" />
                <Button fx:id="pengaturanNavButton" onAction="#showPengaturan" styleClass="menu-button,active" text="⚙ Pengaturan" />
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#goToLogin" styleClass="menu-button" text="⇠ Keluar" />
            </children>
        </VBox>
        <VBox styleClass="content-area" HBox.hgrow="ALWAYS">
            <children>
                <Label fx:id="titleLabel" styleClass="page-title" text="Pengaturan" />
                <Label styleClass="page-subtitle" text="Atur profil dan keamanan akun Anda" />
                <VBox styleClass="form-card" spacing="10">
                    <children>
                        <Label styleClass="section-title" text="Card Profil Admin" />
                        <TextField fx:id="nameField" promptText="Nama" styleClass="text-field" />
                        <TextField fx:id="emailField" promptText="Email" styleClass="text-field" />
                        <Button styleClass="primary-button" text="Simpan" />
                    </children>
                </VBox>
                <VBox styleClass="form-card" spacing="10">
                    <children>
                        <Label styleClass="section-title" text="Card Ganti Password" />
                        <PasswordField fx:id="oldPasswordField" promptText="Password Lama" styleClass="password-field" />
                        <PasswordField fx:id="newPasswordField" promptText="Password Baru" styleClass="password-field" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Konfirmasi Password" styleClass="password-field" />
                        <Button styleClass="primary-button" text="Simpan" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
